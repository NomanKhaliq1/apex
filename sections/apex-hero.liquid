<div class="hero-section full-width hero--{{ section.id }}" style="min-height: {{ section.settings.hero_height }}px;">
  <!-- Background Image or Gradient Overlay -->
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
      class: 'hero__bg-img',
      widths: '375, 550, 750, 1100, 1500, 1780, 2000',
      loading: 'eager',
      sizes: '100vw'
    }}
  {%- else -%}
    <div class="hero__placeholder-gradient"></div>
  {%- endif -%}

  <div class="hero__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

  <!-- Content Container -->
  <div class="hero__content-container page-width align--{{ section.settings.text_alignment }}">
    <div class="hero__content-box {% if section.settings.use_glassmorphism %}glass-panel{% endif %}" style="color: {{ section.settings.text_color }};">
      {%- if section.settings.caption != blank -%}
        <span class="hero__caption">{{ section.settings.caption | escape }}</span>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="hero__subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="hero__actions">
          <a href="{{ section.settings.button_link }}" class="btn btn--primary hero__btn">
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    overflow: hidden;
  }

  .hero__bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero__placeholder-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #121212 0%, #1c1c1c 50%, #2d261e 100%);
    z-index: 1;
  }

  .hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .hero__content-container {
    position: relative;
    z-index: 3;
    display: flex;
    width: 100%;
    padding: var(--spacing-xl) var(--spacing-lg);
    margin: 0 auto;
    max-width: var(--page-width);
  }

  .hero__content-container.align--left {
    justify-content: flex-start;
    text-align: left;
  }

  .hero__content-container.align--center {
    justify-content: center;
    text-align: center;
  }

  .hero__content-container.align--right {
    justify-content: flex-end;
    text-align: right;
  }

  .hero__content-box {
    max-width: 620px;
    padding: var(--spacing-xl);
    border-radius: var(--radius-lg);
    transition: var(--transition-normal);
  }

  .hero__content-box.glass-panel {
    background: rgba(18, 18, 18, 0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .hero__caption {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--spacing-sm);
    color: var(--color-accent-light);
  }

  .hero__heading {
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-md);
    color: inherit;
  }

  .hero__subheading {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.5;
    margin-bottom: var(--spacing-lg);
    opacity: 0.9;
  }

  .hero__subheading p {
    color: inherit;
    margin: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    justify-content: inherit;
  }

  .hero__btn {
    padding: 0.9rem 2.25rem;
    font-size: 1rem;
    box-shadow: 0 4px 14px rgba(79, 70, 229, 0.3);
  }

  .hero__btn:hover {
    box-shadow: 0 6px 20px rgba(79, 70, 229, 0.5);
  }

  /* Text alignment helper override for action buttons flex container */
  .align--center .hero__actions {
    justify-content: center;
  }

  .align--right .hero__actions {
    justify-content: flex-end;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Apex Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 400,
      "max": 800,
      "step": 50,
      "default": 650,
      "unit": "px",
      "label": "Hero Height"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption/Badge text",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Storefront"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Discover the next level of Shopify templates. Fast, conversion-optimized, and premium designed.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "use_glassmorphism",
      "label": "Use Glassmorphism Box",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%",
      "label": "Overlay Opacity"
    }
  ],
  "presets": [
    {
      "name": "Apex Hero Banner"
    }
  ]
}
{% endschema %}
