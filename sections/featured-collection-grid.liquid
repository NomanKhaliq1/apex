<div class="featured-collection section-padding page-width">
  <!-- Section Title -->
  {%- if section.settings.title != blank -%}
    <div class="section-header">
      <h2 class="section-header__title">{{ section.settings.title | escape }}</h2>
      {%- if section.settings.description != blank -%}
        <div class="section-header__description">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <!-- Collection Grid -->
  {%- assign collection = collections[section.settings.collection] -%}
  {%- assign limit = section.settings.products_to_show -%}

  <div class="products-grid grid--{{ section.settings.columns_desktop }}-col">
    {%- if collection != blank and collection.all_products_count > 0 -%}
      {%- for product in collection.products limit: limit -%}
        <div class="grid-item">
          <div class="product-card">
            <!-- Badge -->
            {%- if section.settings.show_badge and product.compare_at_price > product.price -%}
              <span class="product-card__badge">Sale</span>
            {%- endif -%}

            <!-- Image -->
            <div class="product-card__image-wrapper">
              <a href="{{ product.url }}" class="product-card__image-link">
                {%- if product.featured_media != blank -%}
                  {{ product.featured_media | image_url: width: 600 | image_tag:
                    class: 'product-card__image',
                    loading: 'lazy',
                    widths: '165, 360, 533, 720, 940, 1066',
                    sizes: '(min-width: 1100px) 25vw, (min-width: 750px) 33vw, 50vw'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-card__image placeholder' }}
                {%- endif -%}
              </a>
            </div>

            <!-- Details -->
            <div class="product-card__info">
              {%- if section.settings.show_vendor and product.vendor != blank -%}
                <span class="product-card__vendor">{{ product.vendor | escape }}</span>
              {%- endif -%}

              <h3 class="product-card__title">
                <a href="{{ product.url }}">{{ product.title | escape }}</a>
              </h3>

              <div class="product-card__price-container">
                <span class="product-card__price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-card__price product-card__price--compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>

              <!-- Quick Buy Action -->
              <div class="product-card__actions">
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ product.first_available_variant.id }}" />
                  <button type="submit" class="btn btn--secondary btn--full-width" {% unless product.available %}disabled{% endunless %}>
                    {%- if product.available -%}
                      Add to Cart
                    {%- else -%}
                      Sold Out
                    {%- endif -%}
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Placeholder Demo Cards if no collection selected -->
      {%- for i in (1..limit) -%}
        <div class="grid-item">
          <div class="product-card">
            <span class="product-card__badge">Sample</span>
            <div class="product-card__image-wrapper">
              {%- assign placeholder_index = i | modulo: 6 | plus: 1 -%}
              {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'product-card__image placeholder' }}
            </div>
            <div class="product-card__info">
              <span class="product-card__vendor">Brand Partner</span>
              <h3 class="product-card__title"><a href="#">Apex Sample Product {{ i }}</a></h3>
              <div class="product-card__price-container">
                <span class="product-card__price">$49.99</span>
                <span class="product-card__price product-card__price--compare">$79.99</span>
              </div>
              <div class="product-card__actions">
                <button type="button" class="btn btn--secondary btn--full-width" disabled>Demo Add</button>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .section-padding {
    padding-top: var(--spacing-2xl);
    padding-bottom: var(--spacing-2xl);
  }

  .section-header {
    margin-bottom: var(--spacing-xl);
    text-align: center;
  }

  .section-header__title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: var(--spacing-xs);
  }

  .section-header__description {
    color: var(--color-text-muted);
    font-size: 1rem;
    max-width: 60ch;
    margin: 0 auto;
  }

  /* Grid Layouts */
  .products-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .grid--2-col {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid--3-col {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid--4-col {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 769px) {
    .grid--3-col {
      grid-template-columns: repeat(3, 1fr);
    }
    .grid--4-col {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .btn--full-width {
    width: 100%;
    margin-top: var(--spacing-sm);
    font-size: 0.85rem;
    padding: 0.6rem 1rem;
  }

  .product-card__vendor {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 2px;
  }

  .product-card__price-container {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .product-card__price--compare {
    text-decoration: line-through;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .product-card__image-wrapper svg.placeholder {
    width: 100%;
    height: 100%;
    background-color: #f1f5f9;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Check out our trending arrivals, handpicked for you.</p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show sales badge",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid"
    }
  ]
}
{% endschema %}
